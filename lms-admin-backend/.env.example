# Copy to .env and fill in values
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/lms_db
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

